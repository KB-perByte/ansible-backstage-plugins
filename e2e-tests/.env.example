# Base URL for the application under test
BASE_URL=https://your-portal-hostname

# AAP (Ansible Automation Platform) credentials
AAP_USER_ID=<your-aap-username>
AAP_USER_PASS=<your-aap-password>

# AAP API Token (optional - for authenticated API calls)
AAP_TOKEN=<your-aap-api-token>

# GitHub credentials (for RHDH tests)
GH_USER_ID=your-github-username
GH_USER_PASS=your-github-password

# GitHub 2FA TOTP secret (for tests that require 2FA)
AUTHENTICATOR_SECRET=your-base32-totp-secret
