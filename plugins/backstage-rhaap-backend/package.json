{
  "name": "@ansible/backstage-rhaap-backend",
  "description": "Backend plugin for Ansible self-service portal — admin APIs, configuration management, and setup wizard support.",
  "version": "2.1.1",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "private": true,
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
  "backstage": {
    "role": "backend-plugin",
    "pluginId": "rhaap-backend"
  },
  "scripts": {
    "start": "backstage-cli package start",
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack",
    "fix": "backstage-cli repo fix --publish",
    "export-dynamic": "rhdh-cli plugin export --embed-package @ansible/backstage-rhaap-common"
  },
  "dependencies": {
    "@ansible/backstage-rhaap-common": "workspace:^",
    "@backstage/backend-defaults": "^0.11.1",
    "@backstage/backend-plugin-api": "^1.3.1",
    "@backstage/config": "^1.3.2",
    "@backstage/config-loader": "^1.10.1",
    "@backstage/errors": "^1.2.7",
    "@backstage/plugin-permission-common": "^0.9.1",
    "express": "^5.1.0",
    "express-promise-router": "^4.1.1",
    "knex": "^3.1.0",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@backstage/backend-test-utils": "^1.5.0",
    "@backstage/cli": "^0.33.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.3",
    "better-sqlite3": "^11.0.0",
    "supertest": "^7.1.1"
  },
  "files": [
    "dist",
    "dist-dynamic/*.*",
    "dist-dynamic/dist/**",
    "dist-dynamic/alpha/*",
    "build",
    "src/**/*.d.ts"
  ],
  "configSchema": "config.d.ts"
}
